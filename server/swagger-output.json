  "paths": {
    "/user/register": {
      "post": {
        "tags": [
          "Users"
        ],
        "description": "Register a new user",
        "responses": {
          "default": {
            "description": ""
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "email",
                  "password",
                  "confirmed_password",
                  "date_of_birth"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "mailx2"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "mai12435@gmail.com"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "example": "1234@Mai"
                  },
                  "confirmed_password": {
                    "type": "string",
                    "format": "password",
                    "example": "1234@Mai"
                  },
                  "date_of_birth": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2025-03-15T11:58:32Z"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/user/login": {
      "post": {
        "description": "",
        "responses": {
          "default": {
            "description": ""
          }
        }
      }
    },
