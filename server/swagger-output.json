              "schema": {
                "type": "object",
                "required": [
                  "type",
                  "description"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "example": "handbag"
                  },
                  "description": {
                    "type": "string",
                    "example": "Bag to hang the dolls with various sizes"
                  }
                }
              }
            }
          }
        }
      }
    },
