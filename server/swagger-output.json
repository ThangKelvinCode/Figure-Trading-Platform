    "/accessories/{id}/purchase": {
      "post": {
        "tags": [
          "Accessories"
        ],
        "summary": "Purchase an accessory",
        "description": "Handles the purchase of an accessory",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Accessory ID",
            "example": "67bca3f6207e4b98d3665a9f"
          }
        ],
        "responses": {
          "200": {
            "description": "Accessory purchased successfully"
          },
          "400": {
            "description": "Invalid purchase request"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "quantity",
                  "userID"
                ],
                "properties": {
                  "quantity": {
                    "type": "number",
                    "example": 1
                  },
                  "userID": {
                    "type": "string",
                    "example": "67af6d45efd963779dfa5f84"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/accessories/{id}/newReview": {
      "post": {
        "tags": [
          "Accessories"
        ],
        "summary": "Write a review for an accessory",
        "description": "Allows a user to submit a review for an accessory",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Accessory ID",
            "example": "67bca3f6207e4b98d3665a9f"
          }
        ],
        "responses": {
          "201": {
            "description": "Review submitted successfully"
          },
          "400": {
            "description": "Invalid review submission"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "rating",
                  "comment"
                ],
                "properties": {
                  "rating": {
                    "type": "number",
                    "example": 5
                  },
                  "comment": {
                    "type": "string",
                    "example": "Great accessory! Highly recommended."
                  }
                }
              }
            }
          }
        }
      }
    },
