    "/accessories/{id}": {
      "get": {
        "tags": [
          "Accessories"
        ],
        "summary": "Get an accessory by ID",
        "description": "Retrieves details of a specific accessory",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
